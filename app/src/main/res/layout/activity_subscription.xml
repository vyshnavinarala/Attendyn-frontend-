<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/premium_bg"
    tools:context=".SubscriptionActivity">

    <!-- Top Section -->
    <LinearLayout
        android:id="@+id/top_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="60dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.cardview.widget.CardView
            android:layout_width="70dp"
            android:layout_height="70dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/transparent">

            <ImageView
                android:id="@+id/app_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="0dp"
                android:src="@mipmap/ic_launcher"
                android:scaleType="centerCrop" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="sans-serif-black"
            android:text="Attendyn"
            android:textColor="@color/intro_title"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_premium_pill"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp"
            android:text="PREMIUM"
            android:textColor="@color/brand_blue"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />
    </LinearLayout>

    <!-- Heading Subtext -->
    <TextView
        android:id="@+id/subtext"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="40dp"
        android:gravity="center"
        android:text="Unlock smart attendance insights and advanced features designed for your success"
        android:textColor="@color/intro_desc"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_section" />

    <!-- Feature Cards -->
    <LinearLayout
        android:id="@+id/features_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/subtext">

        <!-- Feature 1: Ad-Free -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_feature_card"
            android:padding="16dp">

            <ImageView
                android:id="@+id/ic_feature1"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_flash"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/title_feature1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Ad-Free Experience"
                android:textColor="@color/intro_title"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/check_feature1"
                app:layout_constraintStart_toEndOf="@id/ic_feature1"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/desc_feature1"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/desc_feature1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="No interruptions while tracking attendance"
                android:textColor="@color/intro_desc"
                android:textSize="12sp"
                app:layout_constraintEnd_toStartOf="@id/check_feature1"
                app:layout_constraintStart_toStartOf="@id/title_feature1"
                app:layout_constraintTop_toBottomOf="@id/title_feature1"
                app:layout_constraintBottom_toBottomOf="parent" />

            <ImageView
                android:id="@+id/check_feature1"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_simple_check"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Feature 2: Advanced Analytics -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_feature_card"
            android:padding="16dp">

            <ImageView
                android:id="@+id/ic_feature2"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_diamond"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/title_feature2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Advanced Analytics"
                android:textColor="@color/intro_title"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/check_feature2"
                app:layout_constraintStart_toEndOf="@id/ic_feature2"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/desc_feature2"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/desc_feature2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Detailed insights and trends"
                android:textColor="@color/intro_desc"
                android:textSize="12sp"
                app:layout_constraintEnd_toStartOf="@id/check_feature2"
                app:layout_constraintStart_toStartOf="@id/title_feature2"
                app:layout_constraintTop_toBottomOf="@id/title_feature2"
                app:layout_constraintBottom_toBottomOf="parent" />

            <ImageView
                android:id="@+id/check_feature2"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_simple_check"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

    <!-- Pricing Highlight -->
    <androidx.cardview.widget.CardView
        android:id="@+id/pricing_card"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/features_container">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_premium_btn_gradient"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="0dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Premium Plan"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:alpha="0.8" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹99 / month"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Footer Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_start_premium"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_white_card_rounded"
        android:elevation="0dp"
        android:text="Start Premium"
        android:textAllCaps="false"
        android:textColor="@color/intro_title"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/pricing_card" />

    <TextView
        android:id="@+id/btn_maybe_later"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Maybe later"
        android:textColor="@color/intro_desc"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_start_premium" />

</androidx.constraintlayout.widget.ConstraintLayout>
