<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_lavender_gradient">
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="92dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Top Header -->
            <View
                android:id="@+id/header_bg"
                android:layout_width="match_parent"
                android:layout_height="210dp"
                android:background="@drawable/bg_dashboard_header"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/welcome_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="56dp"
                android:layout_marginEnd="24dp"
                android:fontFamily="sans-serif-black"
                android:text="Welcome back, Guest!"
                android:textColor="@color/white"
                android:textSize="28sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/sub_welcome_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Track your attendance progress"
                android:textColor="#E0E0FF"
                android:textSize="17sp"
                app:layout_constraintStart_toStartOf="@id/welcome_text"
                app:layout_constraintTop_toBottomOf="@id/welcome_text" />

            <!-- Overall Attendance Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/overall_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="20dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="12dp"
                app:layout_constraintTop_toBottomOf="@id/sub_welcome_text">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/overall_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Overall Attendance"
                        android:textColor="#707070"
                        android:textSize="14sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <LinearLayout
                        android:id="@+id/overall_stats_container"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        app:layout_constraintEnd_toStartOf="@+id/overall_progress_container"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/overall_label">

                        <TextView
                            android:id="@+id/overall_percentage_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-black"
                            android:text="0.0%"
                            android:textColor="#1A1C3E"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/overall_risk_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_badge_red_soft"
                            android:maxLines="1"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:singleLine="true"
                            android:text="High"
                            android:textColor="#FF5252"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/overall_goal_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Goal: 75%"
                        android:textColor="#909090"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/overall_stats_container" />

                    <FrameLayout
                        android:id="@+id/overall_progress_container"
                        android:layout_width="85dp"
                        android:layout_height="85dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ProgressBar
                            android:id="@+id/overall_progress_back"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:indeterminate="false"
                            android:max="100"
                            android:progress="100"
                            android:progressDrawable="@drawable/bg_circular_progress_back" />

                        <ProgressBar
                            android:id="@+id/overall_progress_front"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:indeterminate="false"
                            android:max="100"
                            android:progress="0"
                            android:progressDrawable="@drawable/bg_circular_progress_front" />

                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_analysis"
                            app:tint="#D0D0D0" />
                    </FrameLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- Smart Insight Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/insight_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:layout_constraintTop_toBottomOf="@id/overall_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_insight_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_lightbulb"
                        app:tint="#FFB020" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Smart Insight"
                            android:textColor="#1A1C2E"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/insight_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Great! Your attendance is on track."
                            android:textColor="#8B7355"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Quick Actions -->
            <TextView
                android:id="@+id/quick_actions_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="28dp"
                android:text="Quick Actions"
                android:textColor="#1A1C3E"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/insight_card" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/quick_actions_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:paddingHorizontal="24dp"
                android:paddingBottom="12dp"
                app:layout_constraintTop_toBottomOf="@id/quick_actions_title">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_add_subject"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="6dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintEnd_toStartOf="@+id/card_view_analysis"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintWidth_max="130dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <FrameLayout
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:background="@drawable/bg_pink_gradient_rounded">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_open_book" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:fontFamily="sans-serif-bold"
                            android:text="Add Subject"
                            android:textColor="#1A1C3E"
                            android:textSize="14sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_view_analysis"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginStart="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="6dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toEndOf="@+id/card_add_subject"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintWidth_max="130dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <FrameLayout
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:background="@drawable/bg_purple_gradient_rounded">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_analysis"
                                app:tint="@color/white" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:fontFamily="sans-serif-bold"
                            android:gravity="center"
                            android:text="View Analysis"
                            android:textColor="#1A1C3E"
                            android:textSize="14sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Your Subjects Title -->
            <LinearLayout
                android:id="@+id/subjects_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingHorizontal="24dp"
                android:gravity="center_vertical"
                app:layout_constraintTop_toBottomOf="@id/quick_actions_container">

                <TextView
                    android:id="@+id/subjects_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Your Subjects"
                    android:textColor="#1A1C3E"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/view_all_subjects"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View All"
                    android:textColor="@color/btn_purple"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/dashboard_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingBottom="24dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintTop_toBottomOf="@id/subjects_header"
                tools:listitem="@layout/item_dashboard_subject" />

            <!-- Empty State View -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/empty_state_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="60dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/sub_welcome_text">

                <FrameLayout
                    android:id="@+id/illustration_container"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:background="@drawable/bg_empty_state_circle"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_book"
                        app:tint="@color/btn_purple" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tv_empty_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:fontFamily="sans-serif-black"
                    android:text="No Subjects Added Yet"
                    android:textColor="#1A1C2E"
                    android:textSize="24sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/illustration_container" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginHorizontal="48dp"
                    android:gravity="center"
                    android:text="Add your subjects to start tracking your attendance"
                    android:textColor="#545470"
                    android:textSize="17sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_empty_title" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_empty_add_subject"
                    android:layout_width="wrap_content"
                    android:layout_height="56dp"
                    android:layout_marginTop="80dp"
                    android:background="@drawable/bg_btn_send_otp"
                    android:fontFamily="sans-serif-bold"
                    android:paddingHorizontal="32dp"
                    android:text="+ Add Subject"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_empty_title" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Group for Normal Content visibility toggle -->
            <androidx.constraintlayout.widget.Group
                android:id="@+id/normal_state_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:constraint_referenced_ids="overall_card,insight_card,quick_actions_title,quick_actions_container,subjects_header,dashboard_recycler_view" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>



    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="92dp"
        android:background="#E5E7EB" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="92dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        app:elevation="0dp"
        app:itemIconTint="@color/bnv_item_color"
        app:itemTextColor="@color/bnv_item_color"
        app:itemIconSize="24dp"
        app:labelVisibilityMode="labeled"
        app:itemRippleColor="@color/transparent"
        app:itemTextAppearanceActive="@style/TextAppearance.App.BottomNav.Active"
        app:itemTextAppearanceInactive="@style/TextAppearance.App.BottomNav"
        app:menu="@menu/bottom_nav_menu" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="18dp"
        android:src="@drawable/ic_add"
        app:shapeAppearance="@style/ShapeAppearance.App.FAB.Circle"
        app:backgroundTint="@color/btn_purple"
        app:elevation="12sp"
        app:pressedTranslationZ="16dp"
        app:fabSize="normal"
        app:tint="@color/white" />


</androidx.coordinatorlayout.widget.CoordinatorLayout>
