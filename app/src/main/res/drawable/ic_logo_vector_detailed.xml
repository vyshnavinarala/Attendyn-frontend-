<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

    <!-- 1. Outer Soft Glow (Large Radial Gradient) -->
    <path
        android:pathData="M50,50 m-45,0 a45,45 0 1,1 90,0 a45,45 0 1,1 -90,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="50"
                android:centerY="50"
                android:gradientRadius="40"
                android:type="radial">
                <item android:offset="0.0" android:color="#202979FF" /> <!-- Blue center (Reduced glow) -->
                <item android:offset="0.7" android:color="#0800E5FF" /> <!-- Blue fade -->
                <item android:offset="1.0" android:color="#00000000" /> <!-- Transparent edge -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- 2. The Glowing Ring (Sweep Gradient Stroke) -->
    <path
        android:pathData="M50,50 m-35,0 a35,35 0 1,1 70,0 a35,35 0 1,1 -70,0"
        android:strokeWidth="3">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:centerX="50"
                android:centerY="50"
                android:type="sweep">
                <item android:offset="0.0" android:color="#00E5FF" /> <!-- Cyan -->
                <item android:offset="0.25" android:color="#2979FF" /> <!-- Electric Blue -->
                <item android:offset="0.5" android:color="#00E5FF" /> <!-- Cyan -->
                <item android:offset="0.75" android:color="#2979FF" /> <!-- Electric Blue -->
                <item android:offset="1.0" android:color="#00E5FF" /> <!-- Loop back to Cyan -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- Inner Glow for Ring (Another lighter ring) -->
    <path
        android:pathData="M50,50 m-35,0 a35,35 0 1,1 70,0 a35,35 0 1,1 -70,0"
        android:strokeAlpha="0.4"
        android:strokeWidth="6"
        android:strokeColor="#302979FF" />

    <!-- 3. Calendar Icon (Scaled and Centered) components -->
    <group
        android:pivotX="12"
        android:pivotY="12"
        android:scaleX="2.5"
        android:scaleY="2.5"
        android:translateX="38"
        android:translateY="38">
        
        <!-- Calendar Body -->
        <path
            android:fillColor="#FFFFFFFF"
            android:pathData="M19,4h-1V2h-2v2H8V2H6v2H5c-1.11,0 -1.99,0.9 -1.99,2L3,20a2,2 0,0,0 2,2h14c1.1,0 2,-0.9 2,-2V6c0,-1.1 -0.9,-2 -2,-2zM19,20H5V10h14v10zM19,8H5V6h14v2z" />
            
        <!-- Checkmark -->
        <path
            android:fillColor="#FFFFFFFF"
            android:pathData="M9,16.17L4.83,12l-1.42,1.41L9,19 21,7l-1.41,-1.41z" />
            
        <!-- Bars -->
        <path
            android:fillColor="#FFFFFFFF"
            android:pathData="M7,14h2v4H7z M11,12h2v6h-2z M15,10h2v8h-2z" />
    </group>

</vector>
